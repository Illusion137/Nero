    ]
  },
  {
    "name": "Parallel Plate Capacitance",
    "latex": "C = \\frac{e_0 A}{d}",
    "variables": [
      {"name": "C",   "unit": [-2,4,-1,2,0,0,0],  "description": "Capacitance",          "constant": false},
      {"name": "e_0", "unit": [-3,4,-1,2,0,0,0],  "description": "Electric permittivity","constant": true},
      {"name": "A",   "unit": [2,0,0,0,0,0,0],    "description": "Plate area",           "constant": false},
      {"name": "d",   "unit": [1,0,0,0,0,0,0],    "description": "Plate separation",     "constant": false}
    ]
  },
  {
    "name": "Capacitance with Dielectric",
    "latex": "C = \\frac{\\kappa e_0 A}{d}",
    "variables": [
      {"name": "C",       "unit": [-2,4,-1,2,0,0,0],  "description": "Capacitance with dielectric","constant": false},
      {"name": "\\kappa", "unit": [0,0,0,0,0,0,0],    "description": "Dielectric constant",         "constant": false},
      {"name": "e_0",     "unit": [-3,4,-1,2,0,0,0],  "description": "Electric permittivity",       "constant": true},
      {"name": "A",       "unit": [2,0,0,0,0,0,0],    "description": "Plate area",                  "constant": false},
      {"name": "d",       "unit": [1,0,0,0,0,0,0],    "description": "Plate separation",            "constant": false}
    ]
  },
  {
    "name": "Dielectric Constant",
    "latex": "\\kappa = \\frac{C}{C_0}",
    "variables": [
      {"name": "\\kappa", "unit": [0,0,0,0,0,0,0],   "description": "Dielectric constant",           "constant": false},
      {"name": "C",       "unit": [-2,4,-1,2,0,0,0], "description": "Capacitance with dielectric",   "constant": false},
      {"name": "C_0",     "unit": [-2,4,-1,2,0,0,0], "description": "Capacitance without dielectric","constant": false}
    ]
  },
  {
    "name": "Capacitor Energy (voltage)",
    "latex": "U_C = \\frac{1}{2} C V^2",
    "variables": [
      {"name": "U_C", "unit": [2,-2,1,0,0,0,0], "description": "Energy stored in capacitor","constant": false},
      {"name": "C",   "unit": [-2,4,-1,2,0,0,0],"description": "Capacitance",               "constant": false},
      {"name": "V",   "unit": [2,-3,1,-1,0,0,0],"description": "Voltage",                   "constant": false}
    ]
  },
  {
    "name": "Capacitor Energy (charge)",
    "latex": "U_C = \\frac{Q^2}{2 C}",
    "variables": [
      {"name": "U_C", "unit": [2,-2,1,0,0,0,0],  "description": "Energy stored in capacitor","constant": false},
      {"name": "Q",   "unit": [0,1,0,1,0,0,0],   "description": "Stored charge",             "constant": false},
      {"name": "C",   "unit": [-2,4,-1,2,0,0,0], "description": "Capacitance",               "constant": false}
    ]
  },
  {
    "name": "Capacitor Energy (charge and voltage)",
    "latex": "U_C = \\frac{1}{2} Q V",
    "variables": [
      {"name": "U_C", "unit": [2,-2,1,0,0,0,0],  "description": "Energy stored in capacitor","constant": false},
      {"name": "Q",   "unit": [0,1,0,1,0,0,0],   "description": "Stored charge",             "constant": false},
      {"name": "V",   "unit": [2,-3,1,-1,0,0,0], "description": "Voltage",                   "constant": false}
    ]
  },
  {
