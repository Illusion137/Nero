[
  {
    "name": "Terminal Voltage (EMF with internal resistance)",
    "latex": "V_t = \\varepsilon - I r_i",
    "variables": [
      {"name": "V_t",       "unit": [2,-3,1,-1,0,0,0], "description": "Terminal voltage",    "constant": false},
      {"name": "\\varepsilon","unit": [2,-3,1,-1,0,0,0],"description": "EMF of source",       "constant": false},
      {"name": "I",         "unit": [0,0,0,1,0,0,0],   "description": "Current",             "constant": false},
      {"name": "r_i",       "unit": [2,-3,1,-2,0,0,0], "description": "Internal resistance", "constant": false}
    ]
  },
  {
    "name": "Resistors in Series",
    "latex": "R_{eq} = R_1 + R_2",
    "variables": [
      {"name": "R_{eq}", "unit": [2,-3,1,-2,0,0,0], "description": "Equivalent resistance","constant": false},
      {"name": "R_1",    "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 1",          "constant": false},
      {"name": "R_2",    "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 2",          "constant": false}
    ]
  },
  {
    "name": "Resistors in Parallel (two)",
    "latex": "R_{eq} = \\frac{R_1 R_2}{R_1 + R_2}",
    "variables": [
      {"name": "R_{eq}", "unit": [2,-3,1,-2,0,0,0], "description": "Equivalent parallel resistance","constant": false},
      {"name": "R_1",    "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 1",                  "constant": false},
      {"name": "R_2",    "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 2",                  "constant": false}
    ]
  },
  {
    "name": "RC Time Constant",
    "latex": "\\tau = R C",
    "variables": [
      {"name": "\\tau", "unit": [0,1,0,0,0,0,0],   "description": "RC time constant","constant": false},
      {"name": "R",     "unit": [2,-3,1,-2,0,0,0], "description": "Resistance",       "constant": false},
      {"name": "C",     "unit": [-2,4,-1,2,0,0,0], "description": "Capacitance",      "constant": false}
    ]
  },
  {
    "name": "RC Charging (charge)",
    "latex": "q = Q_0 (1 - e^{-t/\\tau})",
    "variables": [
      {"name": "q",   "unit": [0,1,0,1,0,0,0], "description": "Charge at time t",   "constant": false},
      {"name": "Q_0", "unit": [0,1,0,1,0,0,0], "description": "Maximum charge",     "constant": false},
      {"name": "t",   "unit": [0,1,0,0,0,0,0], "description": "Time",               "constant": false},
      {"name": "\\tau","unit": [0,1,0,0,0,0,0],"description": "RC time constant",   "constant": false}
    ]
  },
  {
    "name": "RC Discharging (charge)",
    "latex": "q = Q_0 e^{-t/\\tau}",
    "variables": [
      {"name": "q",   "unit": [0,1,0,1,0,0,0], "description": "Charge at time t",  "constant": false},
      {"name": "Q_0", "unit": [0,1,0,1,0,0,0], "description": "Initial charge",    "constant": false},
      {"name": "t",   "unit": [0,1,0,0,0,0,0], "description": "Time",              "constant": false},
      {"name": "\\tau","unit": [0,1,0,0,0,0,0],"description": "RC time constant",  "constant": false}
    ]
  },
  {
    "name": "Voltage Divider",
    "latex": "V_{out} = V_{in} \\frac{R_2}{R_1 + R_2}",
    "variables": [
      {"name": "V_{out}", "unit": [2,-3,1,-1,0,0,0], "description": "Output voltage",  "constant": false},
      {"name": "V_{in}",  "unit": [2,-3,1,-1,0,0,0], "description": "Input voltage",   "constant": false},
      {"name": "R_1",     "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 1",    "constant": false},
      {"name": "R_2",     "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 2",    "constant": false}
    ]
  },
  {
    "name": "Kirchhoff's Voltage Law (loop)",
    "latex": "\\varepsilon = I R_1 + I R_2",
    "variables": [
      {"name": "\\varepsilon","unit": [2,-3,1,-1,0,0,0],"description": "EMF",            "constant": false},
      {"name": "I",          "unit": [0,0,0,1,0,0,0],   "description": "Current",        "constant": false},
      {"name": "R_1",        "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 1",   "constant": false},
      {"name": "R_2",        "unit": [2,-3,1,-2,0,0,0], "description": "Resistance 2",   "constant": false}
    ]
  },
  {
    "name": "Power Delivered by EMF",
    "latex": "P = \\varepsilon I",
    "variables": [
      {"name": "P",            "unit": [2,-3,1,0,0,0,0],  "description": "Power delivered",  "constant": false},
      {"name": "\\varepsilon", "unit": [2,-3,1,-1,0,0,0], "description": "EMF",              "constant": false},
      {"name": "I",            "unit": [0,0,0,1,0,0,0],   "description": "Current",          "constant": false}
    ]
  },
  {
    "name": "Wheatstone Bridge Balance",
    "latex": "R_x = R_3 \\frac{R_2}{R_1}",
    "variables": [
      {"name": "R_x", "unit": [2,-3,1,-2,0,0,0], "description": "Unknown resistance","constant": false},
      {"name": "R_3", "unit": [2,-3,1,-2,0,0,0], "description": "Known resistance 3","constant": false},
      {"name": "R_2", "unit": [2,-3,1,-2,0,0,0], "description": "Known resistance 2","constant": false},
      {"name": "R_1", "unit": [2,-3,1,-2,0,0,0], "description": "Known resistance 1","constant": false}
    ]
  }
]
